# OpenAI API key — required for the order agent
OPENAI_API_KEY=

# Model — this flow routes between branches via function calls, so it does best with
# a capable model. gpt-4o-mini can mis-route; gpt-4o / gpt-4.1 are recommended.
OPENAI_MODEL=gpt-4o

# Optional: use Google Gemini instead of OpenAI (takes priority when set)
# GOOGLE_GENERATIVE_AI_API_KEY=

# Optional: server port (default 3140)
# PORT=3140
