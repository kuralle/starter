# WhatsApp Cloud API — bring your own number/token (no Embedded Signup)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=          # any secret string you choose for Meta webhook verification
WHATSAPP_WABA_ID=

# Model — OpenAI by default
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: durable conversation window store (in-memory when unset)
# REDIS_URL=redis://127.0.0.1:6379

# Optional: server port (default 3333)
# PORT=3333
