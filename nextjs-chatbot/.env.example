# OpenAI API key — required for the Kuralle agent
OPENAI_API_KEY=

# Optional: override the default model (gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: PostgreSQL connection for durable thread persistence across restarts.
# When unset, threads are stored in MemoryStore (per server process).
# POSTGRES_URL=postgresql://user:password@localhost:5432/kuralle
